{
  "name": "@uniweb/book",
  "version": "0.3.0",
  "description": "Book foundation for Uniweb. Long-form prose with chapters; outputs Typst/PDF, Paged.js HTML, EPUB, and LaTeX. Drives @uniweb/unipress's book/monograph/report/thesis templates.",
  "type": "module",
  "private": true,
  "main": "./src/_entry.generated.js",
  "exports": {
    ".": "./src/_entry.generated.js",
    "./styles": "./src/styles.css",
    "./dist": "./dist/foundation.js",
    "./dist/styles": "./dist/assets/style.css"
  },
  "imports": {
    "#components/*": "./src/components/*",
    "#utils/*": "./src/utils/*"
  },
  "files": ["dist", "src"],
  "scripts": {
    "dev": "vite",
    "build": "uniweb build",
    "build:vite": "vite build"
  },
  "license": "Apache-2.0",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@uniweb/core": "workspace:*",
    "@uniweb/kit": "workspace:*",
    "@uniweb/press": "workspace:*",
    "citestyle": "^1.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@uniweb/build": "workspace:*",
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "uniweb": "workspace:*",
    "vite": "^7.0.0",
    "vite-plugin-svgr": "^4.2.0"
  }
}
