{
  "name": "@uniweb/business-docs",
  "version": "0.1.0",
  "description": "Business documents foundation for Uniweb. Renders statements of work, invoices, and engagement reports from YAML collections, with PDF/DOCX output via Press and XLSX export for filtered reports.",
  "type": "module",
  "private": true,
  "main": "./src/_entry.generated.js",
  "exports": {
    ".": "./src/_entry.generated.js",
    "./styles": "./src/styles.css",
    "./dist": "./dist/foundation.js",
    "./dist/styles": "./dist/assets/style.css"
  },
  "imports": {
    "#components/*": "./src/components/*",
    "#hooks/*": "./src/hooks/*",
    "#utils/*": "./src/utils/*"
  },
  "files": ["dist", "src"],
  "scripts": {
    "dev": "vite",
    "build": "uniweb build",
    "build:vite": "vite build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "license": "Apache-2.0",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@uniweb/core": "workspace:*",
    "@uniweb/kit": "workspace:*",
    "@uniweb/loom": "workspace:*",
    "@uniweb/press": "workspace:*"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@uniweb/build": "workspace:*",
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "uniweb": "workspace:*",
    "vite": "^7.0.0",
    "vitest": "^2.0.0"
  }
}
