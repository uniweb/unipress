name: "{{title}}"
foundation: ../../foundations/book
format: pdf

book:
  title: "{{title}}"
  subtitle: ""
  author: "{{author}}"
  language: en
  rights: "© {{year}} {{author}}."
  trim: royal-octavo
  typography:
    bodySize: 10.5pt
    leading: 0.68em
    firstLineIndent: 1.2em
    bodyFont: ["EB Garamond", "Garamond", "Georgia"]
    headingFont: ["EB Garamond", "Garamond", "Georgia"]
  structure:
    titlePage: true
    copyrightPage: true
    toc: true
    tocDepth: 3
    frontMatterNumbering: roman
  # Citation style for inline cites and the back-matter bibliography.
  # Pick from: chicago-author-date (default — the scholarly humanities
  # convention), apa, mla, harvard, ieee, vancouver, ama, nature, science.
  # Switch the document's whole bibliographic apparatus by changing one
  # value here; nothing else in the project needs editing.
  citationStyle: chicago-author-date
  bibliography:
    sortBy: author

# Bibliographic records the inline `[@key]` cites and the back-matter
# Bibliography section read from. Drop a `.bib` file into
# `collections/bibliography/` — every `@entry{key, ...}` becomes one
# record, with the BibTeX cite key used as the lookup id. YAML and JSON
# files in the same directory are merged in (handy for one-off entries
# you want to maintain by hand alongside an exported `.bib`).
collections:
  bibliography:
    path: collections/bibliography

content:
  - 01-preface
  - 02-introduction
  - 03-chapter-one
  - 99-bibliography
