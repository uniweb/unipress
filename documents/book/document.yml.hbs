name: "{{title}}"
foundation: ../../foundations/book
format: pdf

book:
  title: "{{title}}"
  subtitle: ""
  author: "{{author}}"
  language: en
  rights: "© {{year}} {{author}}. All rights reserved."

  # Trim size. Common values:
  #   trade-6x9  (default), trade-7x10, crown-octavo, royal-octavo, a5
  trim: trade-6x9

  # Front matter and structure.
  structure:
    titlePage: true
    copyrightPage: true
    toc: true
    tocDepth: 2
    frontMatterNumbering: roman

  # Cover artwork. The scaffold ships placeholder front + back files so
  # the first compile produces a complete-looking book; replace both files
  # in `assets/` with your own artwork when you have it. The back cover
  # appears at the end of the PDF; the front is referenced by EPUB
  # readers and most PDF viewers as the book's thumbnail.
  covers:
    front: assets/front.jpg
    back: assets/back.jpg

  # Optional typography overrides. Defaults work for most books — uncomment
  # to customize.
  #
  # typography:
  #   bodySize: 11pt
  #   leading: 0.72em
  #   firstLineIndent: 1.4em
  #   bodyFont: ["EB Garamond", "Garamond", "Georgia"]
  #   headingFont: ["EB Garamond", "Garamond", "Georgia"]

  # Optional citation system. Trade books rarely cite sources; the
  # `monograph` template ships with this turned on by default. To opt in
  # here, uncomment the two blocks below, add a `collections/bibliography/`
  # directory of YAML records, and a `99-bibliography.md` content file
  # with `type: Bibliography`. See the monograph template's README for
  # the full pattern.
  #
  # citationStyle: chicago-author-date
  # bibliography:
  #   sortBy: author

# collections:
#   bibliography:
#     path: collections/bibliography

# Reading order. Files in content/ are sorted by name; the explicit list
# below makes the order predictable. Add new chapters by creating
# content/<name>.md and adding the base name (without `.md`) here.
content:
  - 01-welcome
  - 02-formatting
  - 03-where-next
  - 99-colophon
