name: "{{title}}"
{{#if author}}
author: "{{author}}"
{{/if}}
year: {{year}}

foundation: ../../foundations/data
format: xlsx

# pages/report/ holds one page-folder; everything renders into a single
# downloadable workbook (xlsx) or report (docx).
index: report

collections:
  members:
    path: collections/members
    # Queryable surface — drives the FilterPanel UI. The framework
    # decides whether to ship predicates to a backend or evaluate locally
    # based on `fetcher.supports:`.
    queryable:
      department:
        type: enum
        label: Department
        options: [biology, geology]
      rank:
        type: enum
        label: Rank
        options: [associate, professor]
      tenured:
        type: boolean
        label: Tenured
      start_year:
        type: range
        label: Start year
        min: 1820
        max: 1880
  queries:
    path: collections/queries
