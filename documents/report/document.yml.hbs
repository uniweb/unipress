name: "{{title}}"
foundation: ../../foundations/book
format: pdf

book:
  title: "{{title}}"
  subtitle: ""
  author: "{{author}}"
  language: en
  rights: "© {{year}} {{author}}."
  trim: trade-7x10
  typography:
    bodySize: 10.5pt
    leading: 0.7em
    firstLineIndent: 0pt
    codeMarginRelief: 0.25in
  structure:
    titlePage: true
    copyrightPage: false
    toc: true
    tocDepth: 2
    frontMatterNumbering: none

  # Optional citation system. Reports often cite — primary sources for
  # findings, prior work in methodology, regulatory references. To opt
  # in, uncomment the two blocks below, add a `collections/bibliography/`
  # directory of YAML records, and a content file with `type: Bibliography`
  # at the back. See the `monograph` template's README for the full
  # pattern (style table, two YAML shapes, every cite spelling worked).
  #
  # citationStyle: chicago-author-date
  # bibliography:
  #   sortBy: author

# collections:
#   bibliography:
#     path: collections/bibliography

content:
  - 01-summary
  - 02-findings
  - 03-methodology
